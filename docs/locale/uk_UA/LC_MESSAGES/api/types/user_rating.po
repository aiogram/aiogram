#: ../../api/types/user_rating.rst:3
msgid "UserRating"
msgstr ""

#: aiogram.types.user_rating.UserRating:1 of
msgid ""
"This object describes the rating of a user based on their Telegram Star "
"spendings."
msgstr ""

#: aiogram.types.user_rating.UserRating:3 of
msgid "Source: https://core.telegram.org/bots/api#userrating"
msgstr ""

#: ../../docstring aiogram.types.user_rating.UserRating.level:1 of
msgid ""
"Current level of the user, indicating their reliability when purchasing "
"digital goods and services. A higher level suggests a more trustworthy "
"customer; a negative level is likely reason for concern."
msgstr ""

#: ../../docstring aiogram.types.user_rating.UserRating.rating:1 of
msgid "Numerical value of the user's rating; the higher the rating, the better"
msgstr ""

#: ../../docstring aiogram.types.user_rating.UserRating.current_level_rating:1
#: of
msgid "The rating value required to get the current level"
msgstr ""

#: ../../docstring aiogram.types.user_rating.UserRating.next_level_rating:1 of
msgid ""
"*Optional*. The rating value required to get to the next level; omitted "
"if the maximum level was reached"
msgstr ""
