#: ../../api/types/input_media_sticker.rst:3
msgid "InputMediaSticker"
msgstr ""

#: aiogram.types.input_media_sticker.InputMediaSticker:1 of
msgid "Represents a sticker file to be sent."
msgstr ""

#: aiogram.types.input_media_sticker.InputMediaSticker:3 of
msgid "Source: https://core.telegram.org/bots/api#inputmediasticker"
msgstr ""

#: ../../docstring aiogram.types.input_media_sticker.InputMediaSticker.type:1
#: of
msgid "Type of the result, must be *sticker*"
msgstr ""

#: ../../docstring aiogram.types.input_media_sticker.InputMediaSticker.media:1
#: of
msgid ""
"File to send. Pass a file_id to send a file that exists on the Telegram "
"servers (recommended), pass an HTTP URL for Telegram to get a .WEBP "
"sticker from the Internet, or pass 'attach://<file_attach_name>' to "
"upload a new .WEBP, .TGS, or .WEBM sticker using multipart/form-data "
"under <file_attach_name> name. :ref:`More information on Sending Files » "
"<sending-files>`"
msgstr ""

#: ../../docstring aiogram.types.input_media_sticker.InputMediaSticker.emoji:1
#: of
msgid ""
"*Optional*. Emoji associated with the sticker; only for just uploaded "
"stickers"
msgstr ""
