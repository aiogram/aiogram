#: ../../api/types/input_paid_media_live_photo.rst:3
msgid "InputPaidMediaLivePhoto"
msgstr ""

#: aiogram.types.input_paid_media_live_photo.InputPaidMediaLivePhoto:1 of
msgid "The paid media to send is a live photo."
msgstr ""

#: aiogram.types.input_paid_media_live_photo.InputPaidMediaLivePhoto:3 of
msgid "Source: https://core.telegram.org/bots/api#inputpaidmedialivephoto"
msgstr ""

#: ../../docstring
#: aiogram.types.input_paid_media_live_photo.InputPaidMediaLivePhoto.type:1 of
msgid "Type of the media, must be *live_photo*"
msgstr ""

#: ../../docstring
#: aiogram.types.input_paid_media_live_photo.InputPaidMediaLivePhoto.media:1 of
msgid ""
"Video of the live photo to send. Pass a file_id to send a file that "
"exists on the Telegram servers (recommended) or pass "
"'attach://<file_attach_name>' to upload a new one using multipart/form-"
"data under <file_attach_name> name. :ref:`More information on Sending "
"Files » <sending-files>`. Sending live photos by a URL is currently "
"unsupported."
msgstr ""

#: ../../docstring
#: aiogram.types.input_paid_media_live_photo.InputPaidMediaLivePhoto.photo:1 of
msgid ""
"The static photo to send. Pass a file_id to send a file that exists on "
"the Telegram servers (recommended) or pass 'attach://<file_attach_name>' "
"to upload a new one using multipart/form-data under <file_attach_name> "
"name. :ref:`More information on Sending Files » <sending-files>`. Sending"
" live photos by a URL is currently unsupported."
msgstr ""
