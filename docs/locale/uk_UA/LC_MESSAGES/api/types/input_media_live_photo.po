#: ../../api/types/input_media_live_photo.rst:3
msgid "InputMediaLivePhoto"
msgstr ""

#: aiogram.types.input_media_live_photo.InputMediaLivePhoto:1 of
msgid "Represents a live photo to be sent."
msgstr ""

#: aiogram.types.input_media_live_photo.InputMediaLivePhoto:3 of
msgid "Source: https://core.telegram.org/bots/api#inputmedialivephoto"
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.type:1 of
msgid "Type of the result, must be *live_photo*"
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.media:1 of
msgid ""
"Video of the live photo to send. Pass a file_id to send a file that "
"exists on the Telegram servers (recommended) or pass "
"'attach://<file_attach_name>' to upload a new one using multipart/form-"
"data under <file_attach_name> name. :ref:`More information on Sending "
"Files » <sending-files>`. Sending live photos by a URL is currently "
"unsupported."
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.photo:1 of
msgid ""
"The static photo to send. Pass a file_id to send a file that exists on "
"the Telegram servers (recommended) or pass 'attach://<file_attach_name>' "
"to upload a new one using multipart/form-data under <file_attach_name> "
"name. :ref:`More information on Sending Files » <sending-files>`. Sending"
" live photos by a URL is currently unsupported."
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.caption:1 of
msgid ""
"*Optional*. Caption of the live photo to be sent, 0-1024 characters after"
" entities parsing"
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.parse_mode:1 of
msgid ""
"*Optional*. Mode for parsing entities in the live photo caption. See "
"`formatting options <https://core.telegram.org/bots/api#formatting-"
"options>`_ for more details."
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.caption_entities:1
#: of
msgid ""
"*Optional*. List of special entities that appear in the caption, which "
"can be specified instead of *parse_mode*"
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.show_caption_above_media:1
#: of
msgid ""
"*Optional*. Pass :code:`True`, if the caption must be shown above the "
"message media"
msgstr ""

#: ../../docstring
#: aiogram.types.input_media_live_photo.InputMediaLivePhoto.has_spoiler:1 of
msgid ""
"*Optional*. Pass :code:`True` if the live photo needs to be covered with "
"a spoiler animation"
msgstr ""
